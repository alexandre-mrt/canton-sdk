{
  "name": "canton-sdk",
  "version": "0.1.0",
  "description": "Simple TypeScript SDK for Canton Network dApp development. Zero dependencies, works everywhere.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/react.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bunx biome check --write .",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.8.0",
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0",
    "react": "^19.1.0",
    "@types/react": "^19.1.0",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "keywords": ["canton", "canton-network", "daml", "blockchain", "sdk", "dapp", "defi", "typescript", "web3"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandre-mrt/canton-sdk.git"
  }
}
